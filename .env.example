# Supabase (obligatorio)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Functions (obligatorio si usas IA clinica y/o Google Calendar)
VITE_CLAUDE_PROXY_URL=https://YOUR-PROJECT.supabase.co/functions/v1/clinical-ai
VITE_GOOGLE_CALENDAR_CONNECT_URL=https://YOUR-PROJECT.supabase.co/functions/v1/google-calendar-connect
VITE_GOOGLE_CALENDAR_SYNC_URL=https://YOUR-PROJECT.supabase.co/functions/v1/google-calendar-sync
VITE_GOOGLE_CALENDAR_FETCH_URL=https://YOUR-PROJECT.supabase.co/functions/v1/google-calendar-fetch

# Push notifications (opcional). Genera claves VAPID con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# CAPTCHA Cloudflare Turnstile (opcional, recomendado). Site key PUBLICA del
# widget de Turnstile. El secret key correspondiente va en el panel de Supabase
# (Authentication -> Settings -> CAPTCHA), NO aqui. Si se deja vacio, no se
# muestra el captcha. IMPORTANTE: si activas el CAPTCHA en Supabase, esta site
# key DEBE estar configurada o los inicios de sesion fallaran.
VITE_TURNSTILE_SITE_KEY=

# Sentry (opcional). Si se deja vacio, Sentry no se inicializa
# Crear proyecto React en https://sentry.io y pegar el DSN
VITE_SENTRY_DSN=
